# Admin token for securing the proxy and Railway API
ADMIN_TOKEN=your_admin_token_here

# Same token, exposed to Vite frontend (must match ADMIN_TOKEN)
VITE_ADMIN_TOKEN=your_admin_token_here

# Bale bot token (for Phone Simulator)
BALE_BOT_TOKEN=your_bot_token_here

# Railway API base URL
RAILWAY_API_URL=https://astonishing-respect-production-2505.up.railway.app
